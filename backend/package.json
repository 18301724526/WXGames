{
  "name": "civilization-fire-backend",
  "version": "0.2.0",
  "description": "《文明火种》后端服务 - 全服务端计算架构",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start server.js --name civilization-fire",
