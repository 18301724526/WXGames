const express = require('express');
const bodyParser = require('body-parser');
const Database = require('better-sqlite3');
const { v4: uuidv4 } = require('uuid');
const jwt = require('jsonwebtoken');
const cors = require('cors');
const path = require('path');

const app = express();
const PORT = process.env.PORT || 3000;
const JWT_SECRET = process.env.JWT_SECRET || 'civilization-fire-secret-key-2026';

const DB_PATH = process.env.DB_PATH || path.join(__dirname, 'data', 'game.db');

app.use(cors());
app.use(bodyParser.json());
app.use(bodyParser.urlencoded({ extended: true }));

const db = new Database(DB_PATH);
db.pragma('journal_mode = WAL');

function initDatabase() {
  db.exec(`
    CREATE TABLE IF NOT EXISTS players (
      playerId TEXT PRIMARY KEY,
      deviceId TEXT UNIQUE,
      createdAt TEXT DEFAULT (datetime('now')),
      lastActiveAt TEXT DEFAULT (datetime('now')),
      token TEXT
    )
  `);

  db.exec(`
    CREATE TABLE IF NOT EXISTS game_states (
      playerId TEXT PRIMARY KEY,
      updatedAt TEXT DEFAULT (datetime('now')),
      resources TEXT DEFAULT '{"food":100,"knowledge":0}',
      buildings TEXT DEFAULT '{"farm":0,"house":1,"workshop":0,"academy":0,"barracks":0,"temple":0}',
      population TEXT DEFAULT '{"total":3,"max":5,"farmers":2,"craftsmen":0,"scholars":0,"unassigned":1}',
      techs TEXT DEFAULT '{}',
      currentEra INTEGER DEFAULT 0,
      eraHistory TEXT DEFAULT '[]',
      happiness INTEGER DEFAULT 80,
      gameDay INTEGER DEFAULT 1,
      eventQueue TEXT DEFAULT '[]',
      eventHistory TEXT DEFAULT '[]',
      offlineSnapshot TEXT DEFAULT '{}',
      offlineEventLog TEXT DEFAULT '[]',
      lastEventAt TEXT,
      negativeStreak INTEGER DEFAULT 0,
      FOREIGN KEY (playerId) REFERENCES players(playerId)
    )
  `);

  console.log('Database initialized');
}

initDatabase();

function authMiddleware(req, res, next) {
  const authHeader = req.headers.authorization;
  if (!authHeader || !authHeader.startsWith('Bearer ')) {
    return res.status(401).json({ error: 'Missing token' });
  }
  const token = authHeader.substring(7);
  try {
    const decoded = jwt.verify(token, JWT_SECRET);
    req.playerId = decoded.playerId;
    next();
  } catch (err) {
    return res.status(401).json({ error: 'Invalid token' });
  }
}

function generateToken(playerId) {
  return jwt.sign({ playerId }, JWT_SECRET, { expiresIn: '30d' });
}

function getDefaultGameState(playerId) {
  return {
    playerId,
    resources: { food: 100, knowledge: 0 },
    buildings: { farm: 0, house: 1, workshop: 0, academy: 0, barracks: 0, temple: 0 },
    population: { total: 3, max: 5, farmers: 2, craftsmen: 0, scholars: 0, unassigned: 1 },
    techs: {},
    currentEra: 0,
    eraHistory: [{ era: 0, advancedAt: new Date().toISOString() }],
    happiness: 80,
    gameDay: 1,
    eventQueue: [],
    eventHistory: [],
    offlineSnapshot: {},
    offlineEventLog: [],
    negativeStreak: 0,
    lastEventAt: null,
    updatedAt: new Date().toISOString()
  };
}

function calculateResourceOutput(gameState) {
  const pop = gameState.population;
  const buildings = gameState.buildings;
  const techs = gameState.techs || {};
  const happiness = gameState.happiness || 80;

  function getTechMultiplier(resourceType) {
    let bonus = 1;
    const techEffects = {
      '钻木取火': { food: 0.1 },
      '陶器烧制': { food: 0.15 },
      '灌溉农业': { food: 0.25 },
      '文字记录': { knowledge: 0.2 },
      '天文观测': { knowledge: 0.3 },
      '冶铜技术': { food: 0.1, knowledge: 0.1 }
    };
    for (const [techName, effect] of Object.entries(techEffects)) {
      if (techs[techName]?.status === 'completed') {
        bonus += effect[resourceType] || 0;
      }
    }
    return bonus;
  }

  const farmBonus = 1 + (buildings.farm * 0.5);
  const techFoodBonus = getTechMultiplier('food');
  const happinessBonus = happiness / 100;
  const foodOutput = (pop.farmers || 0) * 0.5 * farmBonus * techFoodBonus * happinessBonus;

  const academyBonus = 1 + (buildings.academy * 0.5);
  const techKnowledgeBonus = getTechMultiplier('knowledge');
  const knowledgeOutput = (pop.scholars || 0) * 0.2 * academyBonus * techKnowledgeBonus;

  return { food: foodOutput, knowledge: knowledgeOutput };
}

function calculateOfflineIncome(gameState, offlineSeconds) {
  const maxOfflineSeconds = 12 * 3600;
  const actualOffline = Math.min(offlineSeconds, maxOfflineSeconds);

  const output = calculateResourceOutput(gameState);
  let offlineEfficiency = 0.8;

  if (gameState.buildings.temple > 0) {
    offlineEfficiency += 0.05 * gameState.buildings.temple;
  }

  const foodIncome = output.food * actualOffline * offlineEfficiency;
  const knowledgeIncome = output.knowledge * actualOffline * offlineEfficiency;

  return {
    food: Math.floor(foodIncome),
    knowledge: Math.floor(knowledgeIncome),
    offlineHours: Math.floor(actualOffline / 36) / 100,
    actualOfflineSeconds: actualOffline
  };
}

function applyOfflineIncome(gameState, offlineIncome) {
  gameState.resources.food = Math.floor((gameState.resources.food || 0) + offlineIncome.food);
  gameState.resources.knowledge = Math.floor((gameState.resources.knowledge || 0) + offlineIncome.knowledge);
}

function getBuildingCost(buildingType, currentCount) {
  const baseCosts = {
    farm: { food: 50 },
    house: { food: 80, knowledge: 10 },
    workshop: { food: 120, knowledge: 30 },
    academy: { food: 150, knowledge: 50 },
    barracks: { food: 200, knowledge: 40 },
    temple: { food: 300, knowledge: 100 }
  };

  const base = baseCosts[buildingType];
  if (!base) return null;

  const multiplier = Math.pow(1.5, currentCount);
  const cost = {};
  for (const [resource, amount] of Object.entries(base)) {
    cost[resource] = Math.floor(amount * multiplier);
  }
  return cost;
}

function canAfford(resources, cost) {
  for (const [resource, amount] of Object.entries(cost)) {
    if ((resources[resource] || 0) < amount) return false;
  }
  return true;
}

function deductResources(resources, cost) {
  for (const [resource, amount] of Object.entries(cost)) {
    resources[resource] = (resources[resource] || 0) - amount;
  }
}

function getTechCost(techName) {
  const techCosts = {
    '钻木取火': { food: 30, knowledge: 20 },
    '陶器烧制': { food: 60, knowledge: 40 },
    '灌溉农业': { food: 100, knowledge: 80 },
    '文字记录': { food: 80, knowledge: 120 },
    '天文观测': { food: 120, knowledge: 200 },
    '冶铜技术': { food: 200, knowledge: 150 },
    '铁器冶炼': { food: 300, knowledge: 250 },
    '哲学思辨': { food: 150, knowledge: 300 }
  };
  return techCosts[techName] || { food: 50, knowledge: 50 };
}

function getEraConditions(era) {
  const conditions = {
    1: {
      food: 500,
      knowledge: 100,
      buildings: { farm: 2, house: 2 },
      techs: ['钻木取火']
    },
    2: {
      food: 2000,
      knowledge: 500,
      buildings: { farm: 5, house: 4, workshop: 2, academy: 1 },
      techs: ['钻木取火', '陶器烧制', '灌溉农业']
    },
    3: {
      food: 5000,
      knowledge: 2000,
      buildings: { farm: 10, house: 8, workshop: 5, academy: 3, barracks: 2, temple: 1 },
      techs: ['钻木取火', '陶器烧制', '灌溉农业', '文字记录', '天文观测', '冶铜技术']
    }
  };
  return conditions[era];
}

function checkEraAdvancement(gameState, targetEra) {
  const conditions = getEraConditions(targetEra);
  if (!conditions) return { canAdvance: false, details: { error: 'Invalid era' } };

  const checks = {
    food: (gameState.resources.food || 0) >= conditions.food,
    knowledge: (gameState.resources.knowledge || 0) >= conditions.knowledge,
    buildings: true,
    techs: true
  };

  for (const [building, required] of Object.entries(conditions.buildings || {})) {
    if ((gameState.buildings[building] || 0) < required) {
      checks.buildings = false;
      break;
    }
  }

  const completedTechs = Object.keys(gameState.techs).filter(t => gameState.techs[t].status === 'completed');
  for (const tech of conditions.techs || []) {
    if (!completedTechs.includes(tech)) {
      checks.techs = false;
      break;
    }
  }

  const allMet = Object.values(checks).every(c => c === true);
  return { canAdvance: allMet, details: checks };
}

function getRecruitCost(currentPopulation) {
  return { food: 50 + (currentPopulation * 5) };
}

function processPopulationGrowth(gameState, deltaSeconds) {
  const growthRate = 0.01;
  const growth = growthRate * deltaSeconds;
  gameState.population.growthProgress = (gameState.population.growthProgress || 0) + growth;

  if (gameState.population.growthProgress >= 1) {
    const newPeople = Math.floor(gameState.population.growthProgress);
    gameState.population.growthProgress -= newPeople;
    gameState.population.total += newPeople;
    gameState.population.unassigned = (gameState.population.unassigned || 0) + newPeople;
  }
}

