const OFFLINE_NARRATIVES = [
  '你离开的这段时间，族人在森林边缘发现了一处清澈的泉水。',
  '夜晚，族人围坐在篝火旁，讲述着古老的故事。',
  '一位年轻的族人学会了用火石生火，大家都为他鼓掌。',
  '附近的猎人带回了几只野兔，部落今晚有肉吃了。',
  '一阵风吹过，带来了远方的花香，族人感到心旷神怡。',
  '孩子们在田野里追逐嬉戏，笑声传遍了整个部落。',
  '一位老者去世，族人举行了庄重的葬礼，缅怀他的智慧。',
  '工匠们尝试新的制陶方法，烧出了更结实的陶器。',
  '一场小雨滋润了农田，庄稼长得更加茂盛了。',
  '远方的商人路过，交换了一些稀有的小饰品。',
  '族人修补了破旧的房屋，准备迎接即将到来的雨季。',
  '一位母亲生下了双胞胎，部落迎来了新生命。'
];

function getOfflineNarrative(offlineHours) {
  const base = OFFLINE_NARRATIVES[Math.floor(Math.random() * OFFLINE_NARRATIVES.length)];
  if (offlineHours >= 2) {
    return `你离开的${offlineHours}小时里，` + base.replace('你离开的这段时间，', '');
  }
  return base;
}

function checkEventTrigger(gameState) {
  const now = Date.now();
  const lastEventTime = gameState.lastEventAt ? new Date(gameState.lastEventAt).getTime() : 0;
  const secondsSinceLastEvent = (now - lastEventTime) / 1000;

  // 120秒冷却
  if (secondsSinceLastEvent < 120) return null;

  // 30%概率
  if (Math.random() > 0.3) return null;

  const candidates = EVENTS.filter(e => e.condition(gameState));
  if (candidates.length === 0) return null;

  // 保护机制：连续2次负面→第3次正面
  if (gameState.negativeStreak >= 2) {
    const positive = candidates.filter(e => {
      const aEffects = e.optionA.effects;
      return !aEffects.happiness || aEffects.happiness >= 0;
    });
    if (positive.length > 0) {
      const event = positive[Math.floor(Math.random() * positive.length)];
      return { ...event, triggeredAt: new Date().toISOString() };
    }
  }

  const event = candidates[Math.floor(Math.random() * candidates.length)];
  return { ...event, triggeredAt: new Date().toISOString() };
}

function isNegativeEvent(event) {
  const aEffects = event.optionA.effects;
  return aEffects.happiness && aEffects.happiness < 0;
}

function applyEventEffects(gameState, effects) {
  if (effects.food) {
    gameState.resources.food = Math.max(0, (gameState.resources.food || 0) + effects.food);
  }
  if (effects.knowledge) {
    gameState.resources.knowledge = Math.max(0, (gameState.resources.knowledge || 0) + effects.knowledge);
  }
  if (effects.happiness) {
    gameState.happiness = Math.max(0, Math.min(100, gameState.happiness + effects.happiness));
  }
  if (effects.population) {
    gameState.population.total += effects.population;
    gameState.population.unassigned = (gameState.population.unassigned || 0) + effects.population;
  }
}

function resolveEvent(gameState, event, option) {
  const chosen = option === 'B' ? event.optionB : event.optionA;

  // 应用效果
  applyEventEffects(gameState, chosen.effects);

  // 记录 streak
  if (isNegativeEvent(event)) {
    gameState.negativeStreak = (gameState.negativeStreak || 0) + 1;
  } else {
    gameState.negativeStreak = 0;
  }

  gameState.lastEventAt = new Date().toISOString();

  // 记录到历史
  gameState.eventHistory.unshift({
    id: event.id,
    title: event.title,
    option,
    narrative: chosen.narrative,
    effects: chosen.effects,
    resolvedAt: new Date().toISOString()
  });

  // 保留最近10条
  if (gameState.eventHistory.length > 10) {
    gameState.eventHistory = gameState.eventHistory.slice(0, 10);
  }

  return { success: true, narrative: chosen.narrative, effects: chosen.effects };
}

function autoProcessEventQueue(gameState) {
  const autoResolved = [];
  while (gameState.eventQueue.length > 5) {
    const oldest = gameState.eventQueue.shift();
    const result = resolveEvent(gameState, oldest, 'A');
    autoResolved.push({
      id: oldest.id,
      title: oldest.title,
      option: 'A',
      narrative: result.narrative,
      autoResolved: true
    });
  }
  return autoResolved;
}

// 离线事件叙事生成
function generateOfflineEvents(gameState, offlineHours) {
  const logs = [];
  const numEvents = Math.min(Math.floor(offlineHours / 2) + 1, 5); // 每2小时一条，最多5条

  for (let i = 0; i < numEvents; i++) {
    logs.push(getOfflineNarrative(offlineHours));
  }

  return logs;
}

// ==================== 数据库操作 ====================

function getPlayer(playerId) {
  const row = db.prepare('SELECT * FROM players WHERE playerId = ?').get(playerId);
  if (!row) return null;
  return {
    playerId: row.playerId,
    deviceId: row.deviceId,
    createdAt: row.createdAt,
    lastActiveAt: row.lastActiveAt
  };
}

function getPlayerByDeviceId(deviceId) {
  const row = db.prepare('SELECT * FROM players WHERE deviceId = ?').get(deviceId);
  if (!row) return null;
  return {
    playerId: row.playerId,
    deviceId: row.deviceId,
    createdAt: row.createdAt,
    lastActiveAt: row.lastActiveAt
  };
}

function createPlayer(deviceId) {
  const playerId = uuidv4();
  const now = new Date().toISOString();
  const token = generateToken(playerId);

  db.prepare('INSERT INTO players (playerId, deviceId, createdAt, lastActiveAt, token) VALUES (?, ?, ?, ?, ?)')
    .run(playerId, deviceId, now, now, token);

  const defaultState = getDefaultGameState(playerId);
  db.prepare(`
    INSERT INTO game_states (
      playerId, resources, buildings, population, techs, currentEra, eraHistory,
      happiness, gameDay, eventQueue, eventHistory, offlineSnapshot, offlineEventLog, updatedAt
    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
  `).run(
    playerId,
    JSON.stringify(defaultState.resources),
    JSON.stringify(defaultState.buildings),
    JSON.stringify(defaultState.population),
    JSON.stringify(defaultState.techs),
    defaultState.currentEra,
    JSON.stringify(defaultState.eraHistory),
    defaultState.happiness,
    defaultState.gameDay,
    JSON.stringify(defaultState.eventQueue),
    JSON.stringify(defaultState.eventHistory),
    JSON.stringify(defaultState.offlineSnapshot),
    JSON.stringify(defaultState.offlineEventLog),
    now
  );

  return { playerId, token };
}

function updatePlayerActivity(playerId) {
  const now = new Date().toISOString();
  db.prepare('UPDATE players SET lastActiveAt = ? WHERE playerId = ?').run(now, playerId);
}

function getGameState(playerId) {
  const row = db.prepare('SELECT * FROM game_states WHERE playerId = ?').get(playerId);
  if (!row) return null;

  return {
    playerId: row.playerId,
    resources: JSON.parse(row.resources),
    buildings: JSON.parse(row.buildings),
    population: JSON.parse(row.population),
    techs: JSON.parse(row.techs),
    currentEra: row.currentEra,
    eraHistory: JSON.parse(row.eraHistory),
    happiness: row.happiness,
    gameDay: row.gameDay,
    eventQueue: JSON.parse(row.eventQueue),
    eventHistory: JSON.parse(row.eventHistory),
    offlineSnapshot: JSON.parse(row.offlineSnapshot || '{}'),
    offlineEventLog: JSON.parse(row.offlineEventLog || '[]'),
    lastEventAt: row.lastEventAt,
    negativeStreak: row.negativeStreak || 0,
    updatedAt: row.updatedAt
  };
}

function saveGameState(gameState) {
  const now = new Date().toISOString();
  db.prepare(`
    UPDATE game_states SET
      resources = ?,
      buildings = ?,
      population = ?,
      techs = ?,
      currentEra = ?,
      eraHistory = ?,
      happiness = ?,
      gameDay = ?,
      eventQueue = ?,
      eventHistory = ?,
      offlineSnapshot = ?,
      offlineEventLog = ?,
      lastEventAt = ?,
      negativeStreak = ?,
      updatedAt = ?
    WHERE playerId = ?
  `).run(
    JSON.stringify(gameState.resources),
    JSON.stringify(gameState.buildings),
    JSON.stringify(gameState.population),
    JSON.stringify(gameState.techs),
    gameState.currentEra,
    JSON.stringify(gameState.eraHistory),
    gameState.happiness,
    gameState.gameDay,
    JSON.stringify(gameState.eventQueue),
    JSON.stringify(gameState.eventHistory),
    JSON.stringify(gameState.offlineSnapshot),
    JSON.stringify(gameState.offlineEventLog),
    gameState.lastEventAt,
    gameState.negativeStreak || 0,
    now,
    gameState.playerId
  );
}

function updateOfflineSnapshot(playerId, snapshot) {
  const now = new Date().toISOString();
  db.prepare('UPDATE game_states SET offlineSnapshot = ?, updatedAt = ? WHERE playerId = ?')
    .run(JSON.stringify(snapshot), now, playerId);
}

// ==================== API 路由 ====================

app.post('/api/player/register', (req, res) => {
  try {
    const { deviceId } = req.body;
    if (!deviceId) {
      return res.status(400).json({ error: 'deviceId is required' });
    }

    let player = getPlayerByDeviceId(deviceId);
    if (player) {
      const token = generateToken(player.playerId);
      db.prepare('UPDATE players SET token = ? WHERE playerId = ?').run(token, player.playerId);
      return res.json({
        playerId: player.playerId,
        token,
        message: 'Player already exists, logged in',
        gameState: getGameState(player.playerId)
      });
    }

    const result = createPlayer(deviceId);
    res.status(201).json({
      playerId: result.playerId,
      token: result.token,
      message: 'Player registered successfully',
      gameState: getGameState(result.playerId)
    });
  } catch (err) {
    console.error('Register error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.post('/api/player/login', (req, res) => {
  try {
    const { deviceId } = req.body;
    if (!deviceId) {
      return res.status(400).json({ error: 'deviceId is required' });
    }

    const player = getPlayerByDeviceId(deviceId);
    if (!player) {
      return res.status(404).json({ error: 'Player not found, please register first' });
    }

    const token = generateToken(player.playerId);
    db.prepare('UPDATE players SET token = ?, lastActiveAt = ? WHERE playerId = ?')
      .run(token, new Date().toISOString(), player.playerId);

    const gameState = getGameState(player.playerId);

    res.json({
      playerId: player.playerId,
      token,
      gameState,
      message: 'Login successful'
    });
  } catch (err) {
    console.error('Login error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.get('/api/game/state', authMiddleware, (req, res) => {
  try {
    const playerId = req.playerId;
    let gameState = getGameState(playerId);

    if (!gameState) {
      return res.status(404).json({ error: 'Game state not found' });
    }

    let offlineIncome = { food: 0, knowledge: 0, offlineHours: 0, actualOfflineSeconds: 0 };
    let offlineEventLog = [];
    const now = Date.now();
    const lastActive = new Date(gameState.updatedAt).getTime();
    const offlineSeconds = (now - lastActive) / 1000;

    // 离线收益计算
    if (offlineSeconds > 60) {
      offlineIncome = calculateOfflineIncome(gameState, offlineSeconds);
      applyOfflineIncome(gameState, offlineIncome);

      // 离线事件叙事
      if (offlineIncome.offlineHours > 0) {
        offlineEventLog = generateOfflineEvents(gameState, offlineIncome.offlineHours);
      }
    }

    // 人口自然增长
    processPopulationGrowth(gameState, offlineSeconds);

    // 在线事件触发（只进入eventQueue，不弹窗）
    let newEvents = [];
    const event = checkEventTrigger(gameState);
    if (event) {
      gameState.eventQueue.push(event);
      newEvents.push(event);
    }

    // 自动处理积压事件（超过5个，自动选A）
    const autoResolved = autoProcessEventQueue(gameState);

    // 更新时间
    gameState.updatedAt = new Date().toISOString();

    // 保存
    saveGameState(gameState);
    updatePlayerActivity(playerId);

    res.json({
      gameState,
      offlineIncome,
      offlineEventLog,
      newEvents,
      autoResolved,
      syncTime: new Date().toISOString()
    });
  } catch (err) {
    console.error('Get game state error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.post('/api/game/action', authMiddleware, (req, res) => {
  try {
    const playerId = req.playerId;
    const { action, target, profession, count, tech, eventId, option } = req.body;

    let gameState = getGameState(playerId);
    if (!gameState) {
      return res.status(404).json({ error: 'Game state not found' });
    }

    let result = { success: false, message: '' };

    switch (action) {
      case 'build': {
        const buildingType = target;
        const currentCount = gameState.buildings[buildingType] || 0;
        const cost = getBuildingCost(buildingType, currentCount);

        if (!cost) {
          result = { success: false, message: 'Invalid building type' };
          break;
        }

        if (!canAfford(gameState.resources, cost)) {
          result = { success: false, message: 'Insufficient resources' };
          break;
        }

        deductResources(gameState.resources, cost);
        gameState.buildings[buildingType] = currentCount + 1;

        if (buildingType === 'house') {
          gameState.population.max += 2;
        }

        result = { success: true, message: `${buildingType} built successfully` };
        break;
      }

      case 'assign': {
        const prof = profession;
        const cnt = count || 1;
        const unassigned = gameState.population.unassigned || 0;

        if (unassigned < cnt) {
          result = { success: false, message: 'Not enough unassigned population' };
          break;
        }

        if (!['farmers', 'craftsmen', 'scholars'].includes(prof)) {
          result = { success: false, message: 'Invalid profession' };
          break;
        }

        gameState.population[prof] = (gameState.population[prof] || 0) + cnt;
        gameState.population.unassigned = unassigned - cnt;

        result = { success: true, message: `${cnt} population assigned to ${prof}` };
        break;
      }

      case 'research': {
        const techName = tech;
        if (gameState.techs[techName]?.status === 'completed') {
          result = { success: false, message: 'Technology already researched' };
          break;
        }

        const cost = getTechCost(techName);
        if (!canAfford(gameState.resources, cost)) {
          result = { success: false, message: 'Insufficient resources' };
          break;
        }

        deductResources(gameState.resources, cost);
        gameState.techs[techName] = {
          status: 'completed',
          completedAt: new Date().toISOString()
        };

        result = { success: true, message: `${techName} researched successfully` };
        break;
      }

      case 'advanceEra': {
        const targetEra = gameState.currentEra + 1;
        const check = checkEraAdvancement(gameState, targetEra);

        if (!check.canAdvance) {
          result = { success: false, message: 'Era advancement conditions not met', details: check.details };
          break;
        }

        gameState.currentEra = targetEra;
        gameState.eraHistory.push({
          era: targetEra,
          advancedAt: new Date().toISOString()
        });

        gameState.happiness = Math.min(100, gameState.happiness + 10);

        result = { success: true, message: `Advanced to era ${targetEra}` };
        break;
      }

      case 'recruit': {
        const recruitCost = getRecruitCost(gameState.population.total);
        if (!canAfford(gameState.resources, recruitCost)) {
          result = { success: false, message: 'Insufficient food to recruit' };
          break;
        }

        if (gameState.population.total >= gameState.population.max) {
          result = { success: false, message: 'Population at maximum capacity, build more houses' };
          break;
        }

        deductResources(gameState.resources, recruitCost);
        gameState.population.total += 1;
        gameState.population.unassigned = (gameState.population.unassigned || 0) + 1;

        result = { success: true, message: 'Recruitment successful' };
        break;
      }

      case 'chooseEvent': {
        const evt = gameState.eventQueue.find(e => e.id === eventId);
        if (!evt) {
          result = { success: false, message: 'Event not found in queue' };
          break;
        }

        const resolveResult = resolveEvent(gameState, evt, option || 'A');

        // 从队列移除
        gameState.eventQueue = gameState.eventQueue.filter(e => e.id !== eventId);

        result = {
          success: true,
          message: `Event ${evt.title} resolved`,
          narrative: resolveResult.narrative,
          effects: resolveResult.effects
        };
        break;
      }

      default:
        result = { success: false, message: 'Unknown action type' };
    }

    // 自动处理积压
    const autoResolved = autoProcessEventQueue(gameState);

    const output = calculateResourceOutput(gameState);

    gameState.updatedAt = new Date().toISOString();
    saveGameState(gameState);
    updatePlayerActivity(playerId);

    res.json({
      ...result,
      gameState,
      resourceOutput: output,
      autoResolved
    });
  } catch (err) {
    console.error('Action error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.post('/api/game/offline', authMiddleware, (req, res) => {
  try {
    const playerId = req.playerId;
    const { offlineAt } = req.body;

    const gameState = getGameState(playerId);
    if (!gameState) {
      return res.status(404).json({ error: 'Game state not found' });
    }

    const snapshot = {
      timestamp: offlineAt || new Date().toISOString(),
      resources: { ...gameState.resources },
      buildings: { ...gameState.buildings },
      population: { ...gameState.population },
      techs: { ...gameState.techs },
      era: gameState.currentEra
    };

    updateOfflineSnapshot(playerId, snapshot);
    updatePlayerActivity(playerId);

    res.json({ success: true, message: 'Offline snapshot recorded' });
  } catch (err) {
    console.error('Offline error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.get('/api/game/events', authMiddleware, (req, res) => {
  try {
    const playerId = req.playerId;
    const gameState = getGameState(playerId);

    if (!gameState) {
      return res.status(404).json({ error: 'Game state not found' });
    }

    res.json({
      pendingEvents: gameState.eventQueue,
      eventHistory: gameState.eventHistory,
      offlineEventLog: gameState.offlineEventLog
    });
  } catch (err) {
    console.error('Get events error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.post('/api/game/event/choose', authMiddleware, (req, res) => {
  try {
    const playerId = req.playerId;
    const { eventId, option } = req.body;

    let gameState = getGameState(playerId);
    if (!gameState) {
      return res.status(404).json({ error: 'Game state not found' });
    }

    const evt = gameState.eventQueue.find(e => e.id === eventId);
    if (!evt) {
      return res.status(404).json({ error: 'Event not found in queue' });
    }

    const resolveResult = resolveEvent(gameState, evt, option || 'A');

    // 从队列移除
    gameState.eventQueue = gameState.eventQueue.filter(e => e.id !== eventId);

    // 自动处理积压
    const autoResolved = autoProcessEventQueue(gameState);

    gameState.updatedAt = new Date().toISOString();
    saveGameState(gameState);

    res.json({
      success: true,
      gameState,
      narrative: resolveResult.narrative,
      effects: resolveResult.effects,
      autoResolved
    });
  } catch (err) {
    console.error('Choose event error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }
});

app.get('/api/health', (req, res) => {
  res.json({ status: 'ok', timestamp: new Date().toISOString() });
});

