#!/bin/bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
BARE_REPO_DIR="$(cd "$HOOK_DIR/.." && pwd)"
WORK_TREE="/www/wwwroot/h5"
BRANCH="main"

while read -r _oldrev _newrev refname; do
    current_branch="${refname#refs/heads/}"
    if [ "$current_branch" != "$BRANCH" ]; then
        continue
    fi

    mkdir -p "$WORK_TREE"
    git --git-dir="$BARE_REPO_DIR" --work-tree="$WORK_TREE" checkout -f "$BRANCH"
    REPO_GIT_DIR="$BARE_REPO_DIR" WORK_TREE="$WORK_TREE" "$WORK_TREE/deploy.sh" "$BRANCH"
done
