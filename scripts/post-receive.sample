#!/bin/bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
BARE_REPO_DIR="$(cd "$HOOK_DIR/.." && pwd -P)"
MAIN_WORK_TREE="/www/wwwroot/h5"

clear_git_local_env() {
    while IFS= read -r var_name; do
        unset "$var_name"
    done < <(git rev-parse --local-env-vars)
}

deploy_ref() {
    local branch="$1"
    local work_tree="$2"
    local deploy_entry="$3"

    clear_git_local_env
    mkdir -p "$work_tree"
    git --git-dir="$BARE_REPO_DIR" --work-tree="$work_tree" checkout -f "$branch"
    REPO_GIT_DIR="$BARE_REPO_DIR" WORK_TREE="$work_tree" bash "$work_tree/$deploy_entry" "$branch"
}

while read -r _oldrev _newrev refname; do
    current_branch="${refname#refs/heads/}"
    case "$current_branch" in
        main)
            deploy_ref "$current_branch" "$MAIN_WORK_TREE" "deploy.sh"
            ;;
        codex/battle-core-test-server)
            deploy_ref "$current_branch" "/www/wwwroot/h5-test-worktree" "scripts/deploy-test-server.sh"
            ;;
        *)
            continue
            ;;
    esac
done
